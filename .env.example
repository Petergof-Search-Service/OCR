# ── Yandex Vision OCR API ───────────────────────────────────────────────────
# Каталог (folder) Yandex Cloud, от имени которого тарифицируются вызовы OCR API
# (заголовок x-folder-id). В обоих окружениях сейчас один и тот же.
FOLDER_ID=b1g0gm5epaeepgfov6ni
# API-ключ сервисного аккаунта с ролью ai.vision (заголовок Authorization: Api-Key ...).
YANDEX_API_KEY=change-me

# ── Смонтированный бакет ─────────────────────────────────────────────────────
# Точка монтирования Object Storage внутри функции: /function/storage/<mount-point>.
# test: /function/storage/petergof-testing-backet
# prod: /function/storage/petergof-incoming-prod
BUCKET_MOUNT_POINT=/function/storage/petergof-testing-backet
# Префикс, по которому фронт кладёт входные PDF (совпадает с prefix bucket-триггера).
INPUT_PREFIX=incoming/
# Куда внутри бакета писать временные и итоговые файлы.
TMP_PREFIX=tmp
RESULT_PREFIX=result

# ── Параметры распознавания (есть дефолты в config.py) ───────────────────────
# 1 — обрабатывать строго по одной странице (дебаг/экономия памяти), 0 — параллельно.
OCR_STRICT_MEMORY_MODE=0
OCR_MAX_CONCURRENT=10
OCR_BATCH_SIZE=2
OCR_CHUNK_SIZE=20
OCR_DPI=100
OCR_JPEG_QUALITY=80

# ── Логирование ──────────────────────────────────────────────────────────────
# Уровень логов: DEBUG | INFO | WARNING | ERROR. По умолчанию INFO.
LOG_LEVEL=INFO

# ── Колбэк статусов в API ────────────────────────────────────────────────────
# Базовый URL API с префиксом версии, без слеша в конце.
# test: https://test.petergof-sciense-rag.ru/api/v1
# prod: https://petergof-sciense-rag.ru/api/v1
API_BASE_URL=https://test.petergof-sciense-rag.ru/api/v1
# Сервисный ключ; должен совпадать с CLOUD_FUNCTION_API_KEY в API.
CLOUD_FUNCTION_API_KEY=change-me
